from collections import defaultdict
def decoding_spectrum(spectrum):
    new_spectrum=[0]+spectrum
    di=defaultdict(list)
    
    for i in range(len(new_spectrum)):
        Tag=set()
        for j in range(i,len(new_spectrum)):
            diff=new_spectrum[j]-new_spectrum[i]
            for key,value in integer_mass_table.items():
                if value==diff and value not in Tag:
                    di[new_spectrum[i]].append((new_spectrum[j],key))
                    Tag.add(value)
    return dict(di)

a=decoding_spectrum(spectrum)

def find_paths(spectrum):
    base=decoding_spectrum(spectrum)
    base_new=base.copy()
    source=0
    sink=spectrum[-1]
    stack=[source]
    path=[]
    adj_list=defaultdict(list)
    
    whole_path=[]
    stack=[(source,[source])]
    for key in base:
        for value in base[key]:
            adj_list[key].append(value[0])
    adj_list_new = {k: v[:] for k, v in adj_list.items()}
    while stack:
        node,path=stack.pop()
        if node==sink:
            whole_path.append(path)
            continue
        for next_node in adj_list_new[node]:
            stack.append((next_node,path+[next_node]))
                         
    return whole_path 
def string(spectrum):
    base=decoding_spectrum(spectrum)
    second=find_paths(spectrum)
    string=""
    answer=[]
    best_value=None
    for path in second:
        string=""
        for idx in range(len(path)-1):
            current_node=path[idx]
            next_node=path[idx+1]
            for end_node,aa in base[current_node]:
                if end_node==next_node:
                    string+=aa
                    break
        answer.append(string)
    return answer
                    
def ideal_spectrum(peptide):
    spect=[]
    
    for i in range(1,len(peptide)+1):
        prefix=peptide[:i]
        b=0
        for amino in prefix:
            b+=integer_mass_table[amino]
        spect.append(b)
    
    for k in range(1, len(peptide)):
        suffix=peptide[k:]
        c=0
        for amino in suffix:
            c+=integer_mass_table[amino]
        spect.append(c)
    return sorted(spect)
def result(spectrum):
    peptides=string(spectrum)
    best_peptide=None
    for peptide in peptides:
        if ideal_spectrum(peptide)==spectrum:
            best_peptide=peptide
    return best_peptide
        
